attribute "fs_serializer";

namespace Pictomatic.Common.Ipc;

table RenderParams (fs_serializer) {
    UblockDir : string (required);
    WebviewCacheDir : string (required);
    DalamudAssemblyDir : string (required);
    DxgiAdapterLuid: long;
    IpcChannelName : string (required);
    KeepAliveHandleName : string (required);
    ParentPid : int;
	Texturehandle: string (required);
    PluginDir : string (required);
}
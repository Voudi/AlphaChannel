include "Enums.fbs";

attribute "fs_serializer";

namespace Pictomatic.Common.Ipc;

table RendererReadyMessage (fs_serializer) {
    HasDxSharedTexturesSupport : bool;
}

table UpdateTextureMessage (fs_serializer) {
    Guid : [ubyte] (required);
    TextureHandle : ulong;
}

table AddSubProcessMessage (fs_serializer) {
    Guid : [ubyte] (required);
    ProcessId : int;
}

table SetCursorMessage (fs_serializer) {
    Cursor: Cursor;
    Guid: [ubyte] (required);
}